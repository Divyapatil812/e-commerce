{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Neo Backend Server",
            "type": "shell",
            "command": "npm",
            "args": ["start"],
            "options": {
                "cwd": "${workspaceFolder}/neocommerce-backend"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*",
                    "endsPattern": "Neo-Backend Live on Port 5000"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": false
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}
